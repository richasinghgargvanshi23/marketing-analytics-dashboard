# .env.example
# Copy this file to .env.local and fill in your real API credentials
# Never commit .env.local to Git!

# ─── Instagram Graph API ───────────────────────────────────────────────────────
# Get from: https://developers.facebook.com/apps/
# Required permissions: instagram_basic, instagram_manage_insights, pages_show_list
REACT_APP_INSTAGRAM_ACCESS_TOKEN=your_instagram_long_lived_access_token_here
REACT_APP_INSTAGRAM_ACCOUNT_ID=your_instagram_business_account_id_here

# ─── YouTube Data API v3 ───────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com/ → APIs & Services → Credentials
# Enable: YouTube Data API v3 + YouTube Analytics API
REACT_APP_YOUTUBE_API_KEY=your_youtube_api_key_here
REACT_APP_YOUTUBE_CHANNEL_ID=your_youtube_channel_id_here
REACT_APP_YOUTUBE_ACCESS_TOKEN=your_youtube_oauth2_access_token_here

# ─── Backend (optional) ────────────────────────────────────────────────────────
# If you build a Node.js/Express backend for campaign data
REACT_APP_BACKEND_URL=http://localhost:5000
